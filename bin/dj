#!/usr/bin/env bash
set -euo pipefail

# ----------------------------------------
# Determine environment
# ----------------------------------------

if [[ "${1:-}" =~ ^(dev|staging|prod)$ ]]; then
  ENV="$1"
  shift
else
  ENV="${APP_ENV:-dev}"
fi

ENV_FILE="$HOME/.config/openchannel/env.${ENV}"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "❌ Environment file not found: $ENV_FILE" >&2
  exit 1
fi

echo "▶ Using APP_ENV=${ENV}"
echo "▶ Loaded env file: ${ENV_FILE}"

# ----------------------------------------
# Execute Django
# ----------------------------------------

exec poetry run python bin/_load_env_and_run.py "$ENV_FILE" manage.py "$@"
